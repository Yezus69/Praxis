<?xml version="1.0" encoding="utf-8"?>
<!--
  Praxis nav_scene.xml — Phase-0 navigation arena for MJX / MuJoCo Playground.

  Topology is FIXED (required under jit/vmap): exactly MAX_OBSTACLES=4 mocap
  movers, one agent body, a floor plane, and 4 perimeter walls. Per-env
  variation (fewer obstacles, randomized start/goal/patrol) is done at runtime
  via an `active` mask + mocap_pos writes + domain randomization of continuous
  fields — NEVER by adding/removing geoms here.

  Arena spans [-3, 3]^2 (contract.ARENA_HALF = 3.0).

  Bodies / dofs (must match nav_env.py assumptions):
    * agent body "agent":
        - slide joint "agent_x" (world x)
        - slide joint "agent_y" (world y)
        - hinge joint "agent_yaw" (world z) — UNACTUATED, kept for fixed obs shape
        - qpos layout: [x, y, yaw]   qvel layout: [vx, vy, omega]
        - velocity actuators "vel_x", "vel_y" drive the two slides via data.ctrl
    * obstacle bodies "obstacle_0".."obstacle_3": mocap="true", each one geom.
        Driven analytically every step via data.replace(mocap_pos=...).
    * "goal_marker": a cosmetic mocap body (sphere site-like geom). The REWARD
        goal lives in state.info['goal']; this marker is only repositioned for
        the rollout video. mocap order in data.mocap_pos is body declaration
        order: obstacle_0,1,2,3 = indices 0..3, goal_marker = index 4.

  NOTE(orchestrator): mocap_pos row indices follow the order mocap bodies are
  declared in the XML. We declare the 4 obstacles FIRST (indices 0..3) then the
  goal marker (index 4). nav_env.py relies on this ordering.
-->
<mujoco model="praxis_nav">
  <compiler angle="radian" coordinate="local" inertiafromgeom="true"/>

  <!-- sim_dt is also set from config in nav_env via mjx model timestep; this is
       the authoring default. n_substeps * timestep = ctrl_dt (~0.05). -->
  <option timestep="0.01" iterations="4" ls_iterations="6" integrator="Euler">
    <flag eulerdamp="disable"/>
  </option>

  <default>
    <geom solref="0.01 1" solimp="0.9 0.95 0.001" condim="3"/>
    <!-- agent slides: light, low friction floor handled by floor geom -->
  </default>

  <asset>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.18 0.20 0.24"
             rgb2="0.10 0.11 0.14" width="300" height="300"/>
    <material name="grid_mat" texture="grid" texrepeat="6 6" reflectance="0.05"/>
    <material name="agent_mat" rgba="0.20 0.60 1.00 1"/>
    <material name="obstacle_mat" rgba="0.95 0.35 0.25 1"/>
    <material name="wall_mat" rgba="0.45 0.47 0.52 1"/>
    <material name="goal_mat" rgba="0.20 0.90 0.40 0.55"/>
  </asset>

  <worldbody>
    <light name="overhead" pos="0 0 6" dir="0 0 -1" diffuse="0.8 0.8 0.8"
           specular="0.1 0.1 0.1" castshadow="false"/>

    <!-- Floor plane (static). Sized a bit larger than the arena. -->
    <geom name="floor" type="plane" size="4 4 0.1" pos="0 0 0"
          material="grid_mat" condim="3" friction="1 0.005 0.0001"/>

    <!-- 4 perimeter walls (static geoms). Inner faces at +/-3.0 = ARENA_HALF.
         Wall center placed at +/-3.1 with half-thickness 0.1 -> inner face 3.0.
         Height 0.5 so a planar agent cannot ride over them. -->
    <geom name="wall_px" type="box" size="0.1 3.2 0.5" pos="3.1 0 0.25"
          material="wall_mat"/>
    <geom name="wall_nx" type="box" size="0.1 3.2 0.5" pos="-3.1 0 0.25"
          material="wall_mat"/>
    <geom name="wall_py" type="box" size="3.2 0.1 0.5" pos="0 3.1 0.25"
          material="wall_mat"/>
    <geom name="wall_ny" type="box" size="3.2 0.1 0.5" pos="0 -3.1 0.25"
          material="wall_mat"/>

    <!-- ================= AGENT ================= -->
    <!-- Two slide joints (x, y) + one yaw hinge. The agent is a low cylinder
         (radius ~0.15) sitting just above the floor. armature/damping keep the
         velocity actuators well-behaved. -->
    <body name="agent" pos="-2.0 0 0.15">
      <joint name="agent_x" type="slide" axis="1 0 0" damping="1.0" armature="0.1"/>
      <joint name="agent_y" type="slide" axis="0 1 0" damping="1.0" armature="0.1"/>
      <joint name="agent_yaw" type="hinge" axis="0 0 1" damping="0.5" armature="0.1"/>
      <!-- SPHERE radius 0.15 == _AGENT_RADIUS used by the geometric collision check.
           NON-COLLIDING (contype=0 conaffinity=0): the env detects collisions
           GEOMETRICALLY (distance to obstacles + arena bounds), so physics contacts
           are not needed — and MJX's narrow-phase produced spurious agent<->wall
           contacts that pinned the agent in place (it could never reach the goal).
           Disabling agent contacts gives clean holonomic point-robot motion; the
           collision PENALTY still fires via the geometric check in nav_env.step. -->
      <geom name="agent_geom" type="sphere" size="0.15" material="agent_mat"
            mass="1.0" contype="0" conaffinity="0"/>
      <!-- A small nose so yaw is visible in the video. -->
      <geom name="agent_nose" type="box" size="0.12 0.03 0.03" pos="0.12 0 0"
            material="agent_mat" mass="0.01" contype="0" conaffinity="0"/>
      <!-- Chase camera that follows the agent for the rollout video. -->
      <camera name="track" mode="trackcom" pos="0 -4.5 4.0" xyaxes="1 0 0 0 0.7 0.7"/>
    </body>

    <!-- ================= OBSTACLES (mocap movers 0..3) ================= -->
    <!-- mocap="true": not physics-integrated (no qpos/qvel) but DO collide.
         Positions written every step via data.mocap_pos. Initial pos here is a
         placeholder; runtime overwrites it. Radius ~0.25 (contract scene spec). -->
    <body name="obstacle_0" mocap="true" pos="0.0 1.5 0.25">
      <geom name="obstacle_0_geom" type="sphere" size="0.25"
            material="obstacle_mat" condim="3"/>
    </body>
    <body name="obstacle_1" mocap="true" pos="0.0 -1.5 0.25">
      <geom name="obstacle_1_geom" type="sphere" size="0.25"
            material="obstacle_mat" condim="3"/>
    </body>
    <body name="obstacle_2" mocap="true" pos="1.5 0.0 0.25">
      <geom name="obstacle_2_geom" type="sphere" size="0.25"
            material="obstacle_mat" condim="3"/>
    </body>
    <body name="obstacle_3" mocap="true" pos="-1.5 0.0 0.25">
      <geom name="obstacle_3_geom" type="sphere" size="0.25"
            material="obstacle_mat" condim="3"/>
    </body>

    <!-- ================= GOAL MARKER (cosmetic mocap, index 4) ================= -->
    <!-- Repositioned for the rollout video to info['goal']; non-colliding. -->
    <body name="goal_marker" mocap="true" pos="2.0 0 0.05">
      <geom name="goal_marker_geom" type="cylinder" size="0.5 0.02"
            material="goal_mat" contype="0" conaffinity="0"/>
      <site name="goal" type="sphere" size="0.08" pos="0 0 0.05" material="goal_mat"/>
    </body>
  </worldbody>

  <!-- Velocity actuators on the two agent slides. ctrl = target linear velocity
       (m/s) along that world axis. nav_env scales policy action in [-1,1] by
       AGENT_MAX_SPEED before writing data.ctrl. The yaw hinge is intentionally
       UNACTUATED (omega stays ~0 but is kept in obs for fixed shape). -->
  <actuator>
    <velocity name="vel_x" joint="agent_x" kv="10.0" ctrlrange="-1.5 1.5"/>
    <velocity name="vel_y" joint="agent_y" kv="10.0" ctrlrange="-1.5 1.5"/>
  </actuator>
</mujoco>
