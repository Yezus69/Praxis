<?xml version="1.0" encoding="utf-8"?>
<!--
  Praxis cover_scene.xml — Phase-0 COVERAGE / exploration arena (REAL physics).

  Task: the agent explores and covers the whole arena while physically colliding
  with walls and obstacles (it cannot pass through them).

  Real-physics agent body (fixes the phantom-contact bug that pinned the old
  goal-nav agent):
    * 2 slide joints (x, y) ONLY — no yaw hinge -> no spurious spinning.
    * Floats at fixed z (no z dof) so there is NO agent<->floor contact (the floor
      contact + free yaw were the source of the spurious contacts).
    * Collision BITMASKS: agent/walls/obstacles share contype=2/conaffinity=2 so the
      agent really collides with walls + obstacles; the floor uses contype=1/
      conaffinity=1 so it never contacts the (floating) agent. The agent therefore
      bounces off walls/obstacles but glides freely in open space.

  Obstacles: 4 mocap movers (contype=2). The env scripts their motion (some static,
  some patrolling) and writes data.mocap_pos every step. They are kinematic, so the
  agent is blocked/bounced by them but they are unaffected.
-->
<mujoco model="praxis_cover">
  <compiler angle="radian" coordinate="local"/>

  <option timestep="0.01" iterations="6" ls_iterations="8" integrator="Euler">
    <flag eulerdamp="disable"/>
  </option>

  <default>
    <geom solref="0.008 1" solimp="0.95 0.99 0.001" condim="3"/>
  </default>

  <asset>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.16 0.18 0.22"
             rgb2="0.10 0.11 0.14" width="300" height="300"/>
    <material name="grid_mat" texture="grid" texrepeat="8 8" reflectance="0.05"/>
    <material name="agent_mat" rgba="0.20 0.65 1.00 1"/>
    <material name="obstacle_mat" rgba="0.95 0.35 0.25 1"/>
    <material name="wall_mat" rgba="0.42 0.45 0.50 1"/>
  </asset>

  <worldbody>
    <light name="overhead" pos="0 0 7" dir="0 0 -1" diffuse="0.85 0.85 0.85"
           specular="0.1 0.1 0.1" castshadow="false"/>

    <!-- Fixed top-down camera (shows the whole arena so coverage is visible). -->
    <camera name="topdown" pos="0 0 9.0" xyaxes="1 0 0 0 1 0"/>

    <!-- Floor (visual only for the agent: contype=1/conaffinity=1, agent floats). -->
    <geom name="floor" type="plane" size="4 4 0.1" pos="0 0 0"
          material="grid_mat" contype="1" conaffinity="1"/>

    <!-- Perimeter walls. Inner faces at +/-3.0 = ARENA_HALF. contype/conaffinity=2
         so the agent collides with them (bounces). -->
    <geom name="wall_px" type="box" size="0.1 3.2 0.5" pos="3.1 0 0.25"
          material="wall_mat" contype="2" conaffinity="2"/>
    <geom name="wall_nx" type="box" size="0.1 3.2 0.5" pos="-3.1 0 0.25"
          material="wall_mat" contype="2" conaffinity="2"/>
    <geom name="wall_py" type="box" size="3.2 0.1 0.5" pos="0 3.1 0.25"
          material="wall_mat" contype="2" conaffinity="2"/>
    <geom name="wall_ny" type="box" size="3.2 0.1 0.5" pos="0 -3.1 0.25"
          material="wall_mat" contype="2" conaffinity="2"/>

    <!-- ================= AGENT (2-DOF, floating, REAL collisions) ============= -->
    <body name="agent" pos="0 0 0.25">
      <joint name="agent_x" type="slide" axis="1 0 0" damping="0.8"/>
      <joint name="agent_y" type="slide" axis="0 1 0" damping="0.8"/>
      <geom name="agent_geom" type="sphere" size="0.15" material="agent_mat"
            mass="1.0" contype="2" conaffinity="2"/>
      <camera name="track" mode="trackcom" pos="0 -5.5 5.0" xyaxes="1 0 0 0 0.7 0.7"/>
    </body>

    <!-- ================= OBSTACLES (mocap movers 0..3, REAL collisions) ======= -->
    <body name="obstacle_0" mocap="true" pos="-1.5 1.5 0.25">
      <geom name="obstacle_0_geom" type="sphere" size="0.25"
            material="obstacle_mat" contype="2" conaffinity="2"/>
    </body>
    <body name="obstacle_1" mocap="true" pos="1.5 1.5 0.25">
      <geom name="obstacle_1_geom" type="sphere" size="0.25"
            material="obstacle_mat" contype="2" conaffinity="2"/>
    </body>
    <body name="obstacle_2" mocap="true" pos="1.5 -1.5 0.25">
      <geom name="obstacle_2_geom" type="sphere" size="0.25"
            material="obstacle_mat" contype="2" conaffinity="2"/>
    </body>
    <body name="obstacle_3" mocap="true" pos="-1.5 -1.5 0.25">
      <geom name="obstacle_3_geom" type="sphere" size="0.25"
            material="obstacle_mat" contype="2" conaffinity="2"/>
    </body>
  </worldbody>

  <!-- Velocity actuators on the two agent slides. ctrl = target velocity (m/s). -->
  <actuator>
    <velocity name="vel_x" joint="agent_x" kv="10.0" ctrlrange="-2.0 2.0"/>
    <velocity name="vel_y" joint="agent_y" kv="10.0" ctrlrange="-2.0 2.0"/>
  </actuator>
</mujoco>
